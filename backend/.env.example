APP_NAME="Home Analytics Platform"
APP_VERSION="0.1.0"
API_V1_PREFIX="/api/v1"
DEBUG=false
DATABASE_URL="sqlite:///./data/sqlite/hap.db"
LOG_LEVEL="INFO"
LOG_DIR="logs"
BACKUP_DIR="data/backups"
BACKUP_AUTO_ENABLED=true
BACKUP_CRON="10 3 * * *"
BACKUP_RETENTION_COUNT=30
GITHUB_BACKUP_ENABLED=false
GITHUB_BACKUP_REPO=""
GITHUB_BACKUP_TOKEN=""
GITHUB_BACKUP_RELEASE_TAG="hap-backups"
GITHUB_BACKUP_ENCRYPTION_PASSPHRASE=""
GITHUB_BACKUP_TIMEOUT_SECONDS=30
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
