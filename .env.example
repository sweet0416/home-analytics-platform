APP_NAME="Home Analytics Platform"
HAP_RELEASE_VERSION="1.0.0"
API_V1_PREFIX="/api/v1"
DEBUG=false
DATABASE_URL="sqlite:////app/data/sqlite/hap.db"
LOG_LEVEL="INFO"
LOG_DIR="/app/logs"
BACKEND_WORKERS=1
BACKEND_KEEP_ALIVE=5
LOTTERY_DLT_AUTO_SYNC_ENABLED=true
LOTTERY_DLT_SYNC_CRON="30 22 * * *"
LOTTERY_DLT_SYNC_PAGE_SIZE=100
LOTTERY_DLT_SYNC_TIMEOUT_SECONDS=30
LOTTERY_DLT_FALLBACK_ENABLED=true
LOTTERY_DLT_SPORTTERY_URL="https://webapi.sporttery.cn/gateway/lottery/getHistoryPageListV1.qry"
LOTTERY_DLT_500_HISTORY_URL="https://datachart.500.com/dlt/history/newinc/history.php"
HAP_WEB_PORT=8088
CORS_ORIGINS='["http://localhost:8088","http://127.0.0.1:8088","http://192.168.100.249:8088"]'
